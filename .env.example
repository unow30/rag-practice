# LLM API (둘 중 하나 설정)
ANTHROPIC_API_KEY=your-claude-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# LLM 모델 설정
LLM_MODEL=claude-sonnet-4-6
# LLM_MODEL=gpt-4o

# 임베딩 / 재정렬 모델
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# 데이터 저장 경로
DATA_DIR=./data

# PostgreSQL 연결 (docker-compose.yml 기준)
# 형식: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://rag-practice:rag-practice@localhost:5434/rag-practice

# RAG 파라미터
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5

# 추출기 선택: pymupdf | pymupdf4llm
EXTRACTOR=pymupdf4llm

# 검색기 선택: faiss | ensemble
RETRIEVER=faiss

# Multi-query 활성화
MULTI_QUERY=false
